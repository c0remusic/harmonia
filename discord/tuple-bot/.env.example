# ─── Tuple Bot configuration ───────────────────────────────
# Copie ce fichier en ".env" et remplis les valeurs.
# NE JAMAIS commit le .env réel (il est ignoré par .gitignore).

# Token du bot — depuis le Developer Portal > Bot > Reset Token
DISCORD_TOKEN=your-bot-token-here

# Application ID (Client ID) — Developer Portal > General Information
CLIENT_ID=your-application-id-here

# ID de ton serveur Discord
GUILD_ID=your-server-id-here

# ─── IDs de rôles ──────────────────────────────────────────

# Rôle attribué automatiquement aux nouveaux membres (clic droit sur le rôle Member > Copier l'ID)
MEMBER_ROLE_ID=1514070684685307976

# ─── IDs de salons (clic droit sur le salon > Copier l'identifiant) ───
WELCOME_CHANNEL_ID=1514027288092737588
ANNOUNCEMENTS_CHANNEL_ID=1514004894485319863
RULES_CHANNEL_ID=1514004894485319862

FAQ_CHANNEL_ID=1514027801844383834
BUG_REPORTS_CHANNEL_ID=1514064619206086666
FEATURE_REQUESTS_CHANNEL_ID=1514004894485319864
GENERAL_HELP_CHANNEL_ID=1514103835822526594

GENERAL_CHANNEL_ID=1514004894485319866
HARMONY_CHANNEL_ID=1514004894485319868


